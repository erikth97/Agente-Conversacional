# ─────────────────────────────────────────────────────────────────────────────
# Banorte — Agente Conversacional de Políticas Operativas
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el archivo .env — está en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — requerido para LLM y embeddings
OPENAI_API_KEY=sk-...tu-api-key-aqui...

# Modelos (defaults seguros si se omiten)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ─── Parámetros RAG ───────────────────────────────────────────────────────────
# Tamaño de chunk en caracteres. 800 captura un párrafo completo de política bancaria.
RAG_CHUNK_SIZE=800

# Overlap entre chunks. 100 chars (~12.5%) preserva frases en bordes de chunk.
RAG_CHUNK_OVERLAP=100

# Dimensión nativa de text-embedding-3-small. No reducir para este volumen de docs.
RAG_EMBEDDING_DIM=1536

# Número de chunks a recuperar. >4 satura el context window, <3 pierde contexto.
RAG_TOP_K=4

# Estrategia de similitud. Cosine es invariante a magnitud — estándar para texto.
RAG_SEARCH_STRATEGY=cosine

# Score mínimo de similitud para usar un chunk en la respuesta del agente.
# Chunks con score < RAG_MIN_SCORE se descartan completamente.
# El agente no inventa información cuando no hay chunks con score suficiente.
RAG_MIN_SCORE=0.5

# ─── ChromaDB ────────────────────────────────────────────────────────────────
# Path relativo al directorio raíz del proyecto.
CHROMA_PATH=./chroma_db

# Nombre de la colección en ChromaDB.
CHROMA_COLLECTION=banorte_procesos

# ─── Base de datos SQLite ─────────────────────────────────────────────────────
DB_PATH=./app/database/banorte.db

# ─── Servidor FastAPI ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
